{
  "name": "fitfi",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend ci || npm --prefix frontend install && npm --prefix frontend run build && rm -rf dist && cp -r frontend/dist ./dist",
    "preview": "npm --prefix frontend run preview"
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend ci || npm --prefix frontend install && npm --prefix frontend run build && rm -rf dist && cp -r frontend/dist ./dist",
    "preview": "npm --prefix frontend run preview",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:netlify": "netlify dev",
    "typecheck": "tsc --noEmit --pretty",
    "build:strict": "npm run typecheck && vite build",
    "test": "vitest run --passWithNoTests",
    "test:routes": "node scripts/test-routes.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "playwright test tests/visual/nova-sse-health.spec.ts --headed",
    "clean:page-footers": "node scripts/codemods/remove-page-footers.mjs",
    "preflight": "node scripts/preflight.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "supabase:setup": "node scripts/supabase-setup.js",
    "supabase:diff": "npx supabase db diff -f",
    "supabase:push": "npx supabase db push",
    "supabase:reset": "npx supabase db reset",
    "supabase:status": "npx supabase status",
    "clean:unused": "node scripts/cleanup/clean-unused.mjs",
    "prepare": "node -e \"if(process.env.CI!=='true'){try{require('child_process').execSync('husky install',{stdio:'inherit'})}catch(e){console.log('husky skipped')}}\""
  },
  "dependencies": {
    "@headlessui/react": "^2.1.2",
    "@supabase/supabase-js": "^2.56.0",
    "@tanstack/react-query": "^5.85.5",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.263.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.4",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.30.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2",
    "postcss": "^8.5.6",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0",
    "supabase": "^2.34.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^5.4.19",
    "vitest": "^1.3.1"
  }
}
