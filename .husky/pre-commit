#!/bin/sh
. "$(dirname -- "$0")/_/husky.sh"

# Check for Python headers in frontend code
if grep -RIlE '(#!/usr/bin/env python3|Robust Wehkamp Scraper)' src; then
  echo '❌ Python header gevonden in frontend code – commit geweigerd'
  echo 'Verwijder alle Python headers uit src/ bestanden voordat je commit.'
  exit 1
fi

echo '✅ Geen Python headers gevonden in frontend code'

# Run unit tests — fast gate voor de testable modules (engine/*)
if [ -f "node_modules/.bin/vitest" ]; then
  echo '🧪 Running vitest unit tests...'
  if ! node_modules/.bin/vitest run --reporter=dot; then
    echo '❌ Unit tests gefaald – commit geweigerd'
    exit 1
  fi
fi

# Run lint-staged
npx lint-staged